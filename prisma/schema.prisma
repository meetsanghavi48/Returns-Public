generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Shopify session storage (required by @shopify/shopify-app-session-storage-prisma)
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// Installed shops with per-shop configuration
model Shop {
  id                 String    @id @default(uuid())
  shop               String    @unique // e.g. "store.myshopify.com"
  accessToken        String
  scopes             String
  installedAt        DateTime  @default(now())
  uninstalledAt      DateTime?
  // Delhivery config
  delhiveryToken     String?
  delhiveryWarehouse String?
  // Easebuzz config
  easebuzzKey        String?
  easebuzzSalt       String?
  easebuzzMid        String?
  easebuzzEnv        String    @default("test")
  // Warehouse details
  warehouseName      String?
  warehouseAddress   String?
  warehouseCity      String?
  warehouseState     String?
  warehousePincode   String?
  warehousePhone     String?
}

// Core return/exchange requests
model ReturnRequest {
  id                  String    @id @default(uuid())
  shop                String
  reqId               String    @unique @default(uuid())
  reqNum              Int?
  orderId             String
  orderNumber         String?
  customerName        String?
  customerEmail       String?
  items               Json      @default("[]")
  refundMethod        String?   // "original" | "store_credit"
  shippingPreference  String    @default("pickup")
  status              String    @default("pending") // pending, approved, pickup_scheduled, in_transit, delivered, refunded, exchanged, rejected, archived
  requestType         String    @default("return") // return | exchange | mixed
  totalPrice          Decimal   @default(0) @db.Decimal(10, 2)
  address             Json?
  isCod               Boolean   @default(false)
  daysSinceOrder      Int       @default(0)
  // AWB tracking
  awb                 String?
  awbStatus           String?
  awbStatusCode       String?
  awbLastScan         Json?
  awbLastChecked      DateTime?
  awbFinal            Boolean   @default(false)
  // Exchange details
  exchangeOrderId     String?
  exchangeOrderName   String?
  exchangeOrderNumber String?
  exchangeShopifyName String?
  // Refund details
  refundId            String?
  refundAmount        Decimal?  @db.Decimal(10, 2)
  utrNumber           String?
  // Auto-action tracking
  autoAction          String?
  // Timestamps
  submittedAt         DateTime  @default(now())
  approvedAt          DateTime?
  pickupCreatedAt     DateTime?
  archivedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shop, orderId])
  @@index([shop, status])
  @@index([shop, awb])
  @@index([shop, approvedAt])
  @@index([shop, createdAt(sort: Desc)])
}

// Per-shop exchange order numbering
model ExchangeCounter {
  id         String @id @default(uuid())
  shop       String @unique
  lastNumber Int    @default(9000)
}

// Per-shop return request sequential numbering (separate counters per type)
model ReturnCounter {
  id         String @id @default(uuid())
  shop       String
  type       String @default("return") // "return" | "exchange" | "mixed"
  lastNumber Int    @default(0)

  @@unique([shop, type])
}

// Audit trail for compliance
model AuditLog {
  id        String   @id @default(uuid())
  shop      String
  orderId   String?
  reqId     String?
  action    String
  actor     String?
  details   String?
  createdAt DateTime @default(now())

  @@index([shop, orderId])
  @@index([shop, createdAt(sort: Desc)])
}

// Per-shop key-value settings
model Settings {
  id        String   @id @default(uuid())
  shop      String
  key       String
  value     Json
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([shop, key])
  @@index([shop])
}

// Return/Exchange reasons configured by merchant
model ReturnReason {
  id              String   @id @default(uuid())
  shop            String
  name            String
  applicableFor   String   @default("both") // "return", "exchange", "both"
  appliesTo       String   @default("all")  // "all" or comma-separated product tags/collections
  message         String?  // Message shown to customer when selecting this reason
  mandatoryOptin  Boolean  @default(false)
  // Refund modes for prepaid orders
  refundPrepaidStoreCredit   Boolean @default(true)
  refundPrepaidOriginal      Boolean @default(true)
  // Refund modes for COD/manual orders
  refundCodStoreCredit       Boolean @default(true)
  refundCodBankTransfer      Boolean @default(false)
  refundCodOther             Boolean @default(false)
  // Requirements
  photoRequired   Boolean  @default(false)
  noteRequired    Boolean  @default(false)
  // Return methods
  methodSendLabel Boolean  @default(false)
  methodShipBack  Boolean  @default(false)
  methodReturnAtStore Boolean @default(false)
  // Region
  region          String   @default("all") // "all" or comma-separated country/region codes
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([shop])
  @@index([shop, applicableFor])
}

// Easebuzz payment records
model Payment {
  id          String   @id @default(uuid())
  shop        String
  txnid       String   @unique
  reqId       String?
  orderId     String
  amount      Decimal  @db.Decimal(10, 2)
  status      String   @default("pending") // pending, success, failed
  txnResponse Json?
  createdAt   DateTime @default(now())

  @@index([shop, orderId])
  @@index([shop, reqId])
}

// Timeline events for returns
model ReturnEvent {
  id        String   @id @default(uuid())
  shop      String
  returnId  String   // references ReturnRequest.id
  type      String   // status_change, note, tracking_update, refund_processed, pickup_scheduled, etc.
  status    String?  // new status if status_change
  message   String?
  metadata  Json?
  actor     String?  // "system", "merchant", "customer"
  createdAt DateTime @default(now())

  @@index([shop, returnId])
  @@index([returnId, createdAt])
}

// Multi-provider logistics credentials
model LogisticsConfig {
  id              String   @id @default(uuid())
  shop            String
  providerKey     String   // e.g. "delhivery", "shiprocket"
  displayName     String
  credentials     String   // encrypted JSON
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  region          String   @default("IN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, providerKey])
  @@index([shop])
}

// Multi-provider payment credentials
model PaymentConfig {
  id              String   @id @default(uuid())
  shop            String
  providerKey     String   // e.g. "razorpay", "stripe"
  displayName     String
  credentials     String   // encrypted JSON
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, providerKey])
  @@index([shop])
}

// WMS provider credentials
model WmsConfig {
  id              String   @id @default(uuid())
  shop            String
  providerKey     String   // e.g. "unicommerce", "zoho_inventory"
  displayName     String
  credentials     String   // encrypted JSON
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, providerKey])
  @@index([shop])
}

// Automation rules engine
model AutomationRule {
  id          String    @id @default(cuid())
  shop        String
  name        String
  description String?
  isActive    Boolean   @default(true)
  matchType   String    @default("ALL") // ALL or ANY
  conditions  Json      @default("[]")
  actions     Json      @default("[]")
  runCount    Int       @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shop])
}

// Automation execution log
model AutomationLog {
  id            String   @id @default(cuid())
  shop          String
  ruleId        String
  ruleName      String
  returnId      String
  conditionsMet Boolean
  actionsRun    Json     @default("[]")
  error         String?
  createdAt     DateTime @default(now())
}
