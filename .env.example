# Shopify App Credentials (from Partners Dashboard)
SHOPIFY_API_KEY=your_client_id_here
SHOPIFY_API_SECRET=your_client_secret_here

# Database (Supabase Direct Connection)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# App URL (set after Render deployment)
SHOPIFY_APP_URL=https://your-app.onrender.com

# Cron Job Secret (generate a random string)
CRON_SECRET=generate_a_random_secret_here

# Encryption Key for adapter credentials (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# SendGrid API Key (for email notifications)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
